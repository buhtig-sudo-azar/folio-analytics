generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// AUTHENTICATION
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String  @id @default(cuid())
  sessionToken String  @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("analyst") // "admin" | "analyst"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

// ==========================================
// ANALYTICS CORE
// ==========================================

// Auto-discovered projects from tracked events
model Project {
  id          String    @id @default(cuid())
  projectId   String    @unique // Identifier from tracking script (e.g., "portfolio-main", "project-chat")
  name        String
  url         String?
  description String?
  deletedAt   DateTime? // Soft delete: when set, project is considered deleted
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  events       Event[]
  pageViews    PageView[]
  conversions  Conversion[]
  goals        Goal[]
}

// All tracked events - the core data table
model Event {
  id            String    @id @default(cuid())
  timestamp     DateTime  @default(now())
  sessionId     String    // Analytics session (not auth session)
  userId        String    // Anonymous user ID (fingerprint-based)
  eventType     String    // page_view, project_view, demo_open, external_link_click, contact_open, contact_form_open, form_submit, click, scroll, mouse_move, custom
  eventName     String?   // Custom event name
  // Page context
  page          String?
  pageTitle     String?
  referrer      String?
  // User context
  userAgent     String?
  browser       String?
  browserVersion String?
  os            String?
  osVersion     String?
  deviceType    String?   // desktop, laptop, tablet, mobile, bot
  deviceModel   String?
  isBot         Boolean   @default(false) // True if visitor is a bot/crawler
  botName       String?   // Name of the bot (e.g., "Googlebot", "Ahrefs")
  screenRes     String?   // e.g., "1920x1080"
  language      String?
  country       String?
  countryCode   String?
  region        String?
  city          String?
  // Traffic context
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  // Event-specific data
  value         Float?    // Numeric value (e.g., scroll depth percentage)
  metadata      String?   // JSON string for additional data
  // Project relation
  projectId     String?   // Can be null if event is on main portfolio
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Indexes for common queries
  @@index([eventType])
  @@index([sessionId])
  @@index([userId])
  @@index([projectId])
  @@index([timestamp])
  @@index([country])
  @@index([deviceType])
  @@index([isBot])
  @@index([eventType, timestamp])
  @@index([projectId, timestamp])
}

// Session-level aggregated data
model AnalyticsSession {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  userId         String   // Anonymous user ID
  projectIds     String   @default("[]") // JSON array of project IDs visited
  // Device info (denormalized for fast queries)
  browser        String?
  os             String?
  deviceType     String?
  screenRes      String?
  language       String?
  country        String?
  countryCode    String?
  region         String?
  city           String?
  // Session metrics
  referrer       String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  // Traffic source classification
  trafficSource  String?   // direct, search, social, referral, utm
  trafficName    String?   // Google, GitHub, Telegram, etc.
  // Session duration
  startedAt      DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  duration       Int       @default(0) // Duration in seconds
  pageViews      Int       @default(0)
  isBounce       Boolean   @default(true) // Single page = bounce
  isNewUser      Boolean   @default(true)
  isBot          Boolean   @default(false) // True if session is from a bot
  botName        String?   // Name of the bot
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([startedAt])
  @@index([country])
  @@index([deviceType])
  @@index([trafficSource])
  @@index([isBot])
}

// Page-level analytics (aggregated from events)
model PageView {
  id          String   @id @default(cuid())
  page        String   // URL path
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  date        String   // YYYY-MM-DD for daily aggregation
  views       Int      @default(0)
  uniqueUsers Int      @default(0)
  avgTimeOnPage Float  @default(0) // In seconds
  exitRate    Float    @default(0) // Percentage
  bounceRate  Float    @default(0) // Percentage
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([page, projectId, date])
  @@index([projectId])
  @@index([date])
}

// Conversion goals
model Goal {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  eventType   String   // The event type that triggers this goal
  eventName   String?  // Optional specific event name
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversions Conversion[]

  @@index([projectId])
  @@index([eventType])
}

// Individual conversion events
model Conversion {
  id        String   @id @default(cuid())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sessionId String
  userId    String
  value     Float?   // Optional conversion value
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  @@index([goalId])
  @@index([projectId])
  @@index([createdAt])
}

// Daily aggregated stats (for fast dashboard queries)
model DailyStats {
  id              String   @id @default(cuid())
  date            String   // YYYY-MM-DD
  projectId       String?  // Null = global
  // Visit metrics
  visits          Int      @default(0)
  uniqueVisitors  Int      @default(0)
  newVisitors     Int      @default(0)
  returningVisitors Int    @default(0)
  // Session metrics
  totalSessions   Int      @default(0)
  avgSessionDuration Float @default(0) // In seconds
  avgPageDepth    Float    @default(0) // Pages per session
  bounceRate      Float    @default(0)
  // Conversion metrics
  conversions     Int      @default(0)
  conversionRate  Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([date, projectId])
  @@index([date])
  @@index([projectId])
}

// Notifications
model Notification {
  id        String   @id @default(cuid())
  type      String   // traffic_spike, traffic_drop, new_country, goal_achieved, conversion_spike
  title     String
  message   String
  severity  String   @default("info") // info, warning, critical
  isRead    Boolean  @default(false)
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

// Heatmap data points
model HeatmapPoint {
  id          String   @id @default(cuid())
  page        String
  projectId   String?
  type        String   // click, scroll, mouse_move
  x           Int      // X coordinate (relative)
  y           Int      // Y coordinate (relative)
  width       Int      // Viewport width at time of event
  height      Int      // Viewport height at time of event
  element     String?  // CSS selector of clicked element
  value       Float?   // Scroll depth percentage for scroll events
  createdAt   DateTime @default(now())

  @@index([page, type])
  @@index([projectId])
}
